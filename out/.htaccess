<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Handle the _next folder which often causes 404s on Hostinger
  RewriteRule ^_next/(.*)$ _next/$1 [L]

  # Redirect everything else to index.html to handle Next.js routing
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>